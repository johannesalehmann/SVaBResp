mdp

label "obj" = z=false;

const x_min = -2;
const x_max = 2;

const y_min = 12;
const y_max = 17;

const int test_const_1 = 1;
const int test_const_2 = 2;
const int test_const_3 = 3;

module main
    x: [x_min..x_max];
    y: [y_min..y_max];
    z: bool init true;
    w: [4..5];

    [] (x<x_max) -> (x'=x+1);
    [] (y=y_min & w=4 & x=2) -> (z'=false);
    [] (w<5) -> (w'=w+1);
endmodule